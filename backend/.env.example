PORT=5000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=your_db_password
DB_NAME=ndrwebsite

# JWT
JWT_SECRET=your_strong_random_secret_here
REGISTRATION_OTP_SECRET=use_a_separate_strong_random_secret_here

# CORS - frontend ka URL daalo
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@example.com
SMTP_FROM_NAME=National Data Repository
SMTP_REPLY_TO=support@example.com

# CCAvenue Payment Gateway
CCA_MERCHANT_ID=your_merchant_id
CCA_WORKING_KEY=your_working_key
CCA_ACCESS_CODE=your_access_code
CCA_REDIRECT_URL=http://localhost:5000/api/payment/callback
CCA_CANCEL_URL=http://localhost:3000/payment-failed

NODE_ENV=production
